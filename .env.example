# Discord bot token.
# Get this from https://discord.com/developers/applications.
DISCORD_TOKEN=

# Active server.
SERVER_PROVIDER=pterodactyl
MINECRAFT_SERVER_ADDR=localhost:25565

# Play Hosting / Pterodactyl. Required when SERVER_PROVIDER=pterodactyl.
PTERODACTYL_PANEL_URL=https://panel.play.hosting
PTERODACTYL_SERVER_ID=
PTERODACTYL_API_TOKEN=
# Keep false for a read-only canary, then enable after diagnostics succeed.
PTERODACTYL_POWER_ENABLED=false
# Maximum time to wait for Play Hosting to allocate a sleeping server.
PTERODACTYL_ALLOCATION_WAIT_SECS=1200
FLARESOLVERR_URL=http://127.0.0.1:8191/
FLARESOLVERR_CONTAINER=flaresolverr
# Optional command-path overrides for local macOS operation.
# ORBSTACK_BIN=/opt/homebrew/bin/orbctl
# DOCKER_BIN=/usr/local/bin/docker

# Aternos rollback settings. Required only when SERVER_PROVIDER=aternos.
ATERNOS_USER=
ATERNOS_PASS=
ATERNOS_SERVER_ID=
HEADLESS=true
# CHROME=/usr/bin/chromium

# Runtime behavior.
START_WAIT_ONLINE_SECS=600
RUN_HISTORY_LIMIT=20
ARTIFACT_DIR=artifacts/runs
ARTIFACT_CAPTURE=screenshots
BUTLER_ATTACH_SCREENSHOTS=true

# Comma-separated Discord user IDs authorized for restricted diagnostics/history commands.
# Guild members with Discord Administrator are also authorized inside that guild.
BUTLER_OWNER_IDS=

# Persist step-level JSONL diagnostics under ARTIFACT_DIR.
# These files are local-only and ignored by git.
BUTLER_PERSIST_RUN_EVENTS=true
BUTLER_REDACT_RUN_EVENTS=true

# Console and tracing output.
BUTLER_LOG=info
BUTLER_COLOR=true
