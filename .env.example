# Discord bot token.
# Get this from https://discord.com/developers/applications.
DISCORD_TOKEN=

# Aternos credentials for the current browser-backed server provider.
ATERNOS_USER=
ATERNOS_PASS=
SERVER_ID=

# Minecraft server address used by /server status, /server diagnose, and start preflight.
MINECRAFT_SERVER_ADDR=localhost:25565

# Browser automation.
HEADLESS=true
# Optional explicit Chrome/Chromium executable path if auto-detection fails.
# CHROME=/usr/bin/chromium

# Runtime behavior.
START_WAIT_ONLINE_SECS=600
RUN_HISTORY_LIMIT=20
ARTIFACT_DIR=artifacts/runs
ARTIFACT_CAPTURE=screenshots
BUTLER_ATTACH_SCREENSHOTS=true

# Comma-separated Discord user IDs authorized for restricted diagnostics/history commands.
# Guild members with Discord Administrator are also authorized inside that guild.
BUTLER_OWNER_IDS=

# Persist step-level JSONL diagnostics under ARTIFACT_DIR.
# These files are local-only and ignored by git.
BUTLER_PERSIST_RUN_EVENTS=true
BUTLER_REDACT_RUN_EVENTS=true

# Console and tracing output.
BUTLER_LOG=info
BUTLER_COLOR=true
